DATABASE_URL="postgresql://user:password@localhost:5432/energy_meter_db"

PORT=3020
NODE_ENV=development

# Upload settings
UPLOAD_PATH=uploads
MAX_FILE_SIZE=10485760
MAX_FILES_PER_UPLOAD=10

# Rate limiting
RATE_LIMIT_MAX=100

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# External services
PLN_CODE_SERVICE_URL=http://localhost:3007
